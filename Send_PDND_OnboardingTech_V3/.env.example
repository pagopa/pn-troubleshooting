# Ambiente: prod oppure uat.
ENV=prod
BASE_URL=<pdnd-base-host>
SERVICE_ID=<send-eservice-id>
ISSUER=<pdnd-client-id>
KID=<pdnd-key-id>

# Chiave della client assertion per l'esecuzione locale.
PRIVATE_KEY_PATH=/absolute/path/client_assertion_private.pem

PDND_MIN_REQUEST_INTERVAL_MS=750
CLIENT_ASSERTION_TTL_SECONDS=600

# Accesso DynamoDB locale. In Lambda vengono usati ruolo e regione della funzione.
AWS_PROFILE=sso_pn-core-prod-ro
AWS_REGION=eu-south-1
ONBOARD_INSTITUTIONS_TABLE=pn-OnboardInstitutions
API_KEYS_TABLE=pn-apiKey

ONBOARDING_REPORT_PATH=reports/out-onBoardingTech.csv
